# Quando .easignore existe, o EAS usa-o NO LUGAR do .gitignore.
# É uma cópia do .gitignore SEM excluir GoogleService-Info.plist / google-services.json,
# pois o build EAS precisa desses ficheiros (estão fora do git por higiene do repo público).

# dependencies
node_modules/

# Expo
.expo/
dist/
web-build/
expo-env.d.ts

# Native
.kotlin/
*.orig.*
*.jks
*.p8
*.p12
*.key
*.mobileprovision

# Metro
.metro-health-check*

# debug
npm-debug.*
yarn-debug.*
yarn-error.*

# macOS
.DS_Store
*.pem

# local env files
.env
.env*.local

# typescript
*.tsbuildinfo

# generated native folders
/ios
/android

# Firestore rules
firestore.rules

# Firebase deploy cache
.firebase/

# não necessários no build
docs/
.git/
