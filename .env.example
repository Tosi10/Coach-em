# Coach'em – variáveis de ambiente
# Copie para .env e preencha quando criar a conta e o DB.
# No Expo, use o prefixo EXPO_PUBLIC_ para expor ao app.
#
# EAS Build: copie estas mesmas chaves para o projeto no expo.dev → Environment variables
# (não commite valores no eas.json).

# ========== Firebase (Firebase Console > Project Settings > General) ==========
EXPO_PUBLIC_FIREBASE_API_KEY=
EXPO_PUBLIC_FIREBASE_AUTH_DOMAIN=
EXPO_PUBLIC_FIREBASE_PROJECT_ID=
EXPO_PUBLIC_FIREBASE_STORAGE_BUCKET=
EXPO_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
EXPO_PUBLIC_FIREBASE_APP_ID=

# ========== RevenueCat (dashboard > Project > API keys — chave PÚBLICA iOS "appl_...") ==========
# Necessária para IAP no app. Sem isto o SDK não inicializa (o resto do app funciona).
EXPO_PUBLIC_REVENUECAT_IOS_API_KEY=
# Quando tiver Android na loja:
# EXPO_PUBLIC_REVENUECAT_ANDROID_API_KEY=

# ========== API REST (opcional – quando tiver backend próprio) ==========
# EXPO_PUBLIC_API_URL=https://sua-api.com/v1
