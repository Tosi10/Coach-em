rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {

    // Imagens das salas do CooPs
    match /rooms/{roomId}/{imageId} {
      // Qualquer usuário logado pode ver imagens das salas
      allow read: if request.auth != null;

      // Só ADMIN do CooPs pode enviar/alterar imagens
      allow write: if request.auth != null &&
        get(
          /databases/(default)/documents/coopsUsers/$(request.auth.uid)
        ).data.role == 'admin';
    }

    // Fotos de perfil (Treina+ / Coach-em) — pasta profilePhotos/{userId}/...
    match /profilePhotos/{userId}/{allPaths=**} {
      // Quem tem o link (URL com token) consegue exibir; ou só logados
      allow read: if true;

      // Só o próprio usuário envia/altera a própria pasta
      allow write: if request.auth != null && request.auth.uid == userId;
    }

    // Vídeos de exercícios (Treina+) — pasta exercises/{exerciseId}/...
    match /exercises/{exerciseId}/{fileName} {
      allow read: if true;
      allow write: if request.auth != null
        && exists(/databases/(default)/documents/coachemExercises/$(exerciseId))
        && get(/databases/(default)/documents/coachemExercises/$(exerciseId)).data.createdBy
          == request.auth.uid;
    }

    // Nada fora das pastas acima (evita bucket partilhado aberto a qualquer user logado).
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
