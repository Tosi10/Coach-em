{
  "expo": {
    "name": "Treina+",
    "slug": "coachemapp",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/TreinaLogo2.1.png",
    "scheme": "coachemapp",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/images/TreinaLogo2.1.png",
      "resizeMode": "contain",
      "backgroundColor": "#0a0a0a"
    },
    "ios": {
      "bundleIdentifier": "com.vision10.coachem",
      "buildNumber": "1.0.2",
      "supportsTablet": true,
      "splash": {
        "backgroundColor": "#0a0a0a"
      },
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "com.coachem.app",
      "versionCode": 1,
      "allowBackup": false,
      "softwareKeyboardLayoutMode": "resize",
      "splash": {
        "backgroundColor": "#0a0a0a"
      },
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/TreinaLogo2.1.png",
        "backgroundColor": "#0a0a0a"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "navigationBar": {
        "backgroundColor": "#0a0a0a",
        "barStyle": "light-content"
      }
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/TreinaLogo2.1.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-image-picker",
        {
          "photosPermission": "O app precisa acessar fotos e vídeos da galeria para imagem de perfil e vídeos de exercícios.",
          "cameraPermission": "Não utilizamos a câmera nesta versão; o SDK de mídia pode declarar esta permissão."
        }
      ],
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#0a0a0a",
          "image": "./assets/images/TreinaLogo2.1.png",
          "imageWidth": 200,
          "resizeMode": "contain"
        }
      ],
      [
        "expo-navigation-bar",
        {
          "backgroundColor": "#0a0a0a",
          "barStyle": "light-content"
        }
      ],
      [
        "@sentry/react-native",
        {
          "url": "https://sentry.io/",
          "organization": "v6core",
          "project": "coachemapp"
        }
      ],
      "expo-font"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "882f63be-2b20-4a26-8b98-a9c1538e0b2d"
      }
    },
    "owner": "v6core"
  }
}
