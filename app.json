{
  "expo": {
    "name": "Coach'em",
    "slug": "coachemapp",
    "version": "1.0.1",
    "orientation": "portrait",
    "icon": "./assets/images/Coach-emIcone02.png",
    "scheme": "coachemapp",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/images/Coach-emNovo03.png",
      "resizeMode": "contain",
      "backgroundColor": "#0a0a0a"
    },
    "ios": {
      "bundleIdentifier": "com.vision10.coachem",
      "buildNumber": "1.0.25",
      "icon": "./assets/images/Coach-emIcone02.png",
      "googleServicesFile": "./GoogleService-Info.plist",
      "supportsTablet": true,
      "splash": {
        "backgroundColor": "#0a0a0a"
      },
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "com.vision10.coachem",
      "versionCode": 1,
      "allowBackup": false,
      "softwareKeyboardLayoutMode": "resize",
      "googleServicesFile": "./google-services.json",
      "splash": {
        "backgroundColor": "#0a0a0a"
      },
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/Coach-emIcone02.png",
        "backgroundColor": "#0a0a0a"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "android.permission.health.READ_HEART_RATE",
        "android.permission.health.READ_ACTIVE_CALORIES_BURNED",
        "android.permission.health.READ_DISTANCE",
        "android.permission.health.READ_STEPS",
        "android.permission.health.READ_EXERCISE"
      ]
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/Coach-emIcone02.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-image-picker",
        {
          "photosPermission": "O app precisa acessar fotos e vídeos da galeria para imagem de perfil e vídeos de exercícios.",
          "cameraPermission": "Não utilizamos a câmera nesta versão; o SDK de mídia pode declarar esta permissão."
        }
      ],
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#0a0a0a",
          "image": "./assets/images/Coach-emNovo03.png",
          "imageWidth": 200,
          "resizeMode": "contain"
        }
      ],
      [
        "expo-navigation-bar",
        {
          "backgroundColor": "#0a0a0a",
          "barStyle": "light-content"
        }
      ],
      [
        "@sentry/react-native",
        {
          "url": "https://sentry.io/",
          "organization": "v6core",
          "project": "coachemapp"
        }
      ],
      "expo-font",
      "expo-video",
      "expo-audio",
      "expo-asset",
      "expo-web-browser",
      [
        "react-native-health",
        {
          "isClinicalDataEnabled": false,
          "healthSharePermission": "O Coach'em utiliza os seus dados de saúde (frequência cardíaca, calorias e treinos registados no Apple Watch) durante a sessão de treino para que o seu treinador acompanhe a sua evolução. A partilha é opcional e pode ser desativada a qualquer momento.",
          "healthUpdatePermission": "O Coach'em pode registar treinos concluídos no app Saúde para manter o seu histórico unificado. A gravação é opcional."
        }
      ],
      "react-native-health-connect",
     "./node_modules/@react-native-firebase/app/app.plugin.js",
     "./node_modules/@react-native-firebase/app-check/app.plugin.js"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "882f63be-2b20-4a26-8b98-a9c1538e0b2d"
      }
    },
    "owner": "v6core"
  }
}
